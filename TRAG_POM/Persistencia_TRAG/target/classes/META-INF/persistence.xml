<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence           http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
  <persistence-unit name="ConexionTRAG" transaction-type="RESOURCE_LOCAL">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <class>entidades.prueba</class>
    <class>entidades.Usuario</class>
    <class>entidades.Cliente</class>
    <class>entidades.Proveedor</class>
    <class>entidades.Servicio</class>
    <class>entidades.Cotizacion</class>
    <class>entidades.Insumo</class>
    <class>entidades.Automovil</class>
    <class>entidades.InsumoServicio</class>
    <class>entidades.Cita</class>
    <class>entidades.InsumoCotizacion</class>
    <class>entidades.OrdenTrabajo</class>
    <class>entidades.DetallePago</class>
    <class>entidades.Trabajo</class>
    <class>entidades.Imprevisto</class>
    <class>entidades.InsumoTrabajoAdquirido</class>
    <class>entidades.InsumoImprevisto</class>
    <properties>
      <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/trag_db?zeroDateTimeBehavior=CONVERT_TO_NULL"/>
      <property name="javax.persistence.jdbc.user" value="root"/>
      <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="javax.persistence.jdbc.password" value="itson"/>
      <property name="javax.persistence.schema-generation.database.action" value="create"/>
    </properties>
  </persistence-unit>
</persistence>